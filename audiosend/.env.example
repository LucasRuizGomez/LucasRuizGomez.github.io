# ════════════════════════════════════════════════════════
# SongSender — .env.example
#
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git. Add it to .gitignore.
# ════════════════════════════════════════════════════════

# ── YOUR SITE ──────────────────────────────────────────
# The URL where your site is hosted (no trailing slash)
SITE_URL=https://yourdomain.com

# ── STRIPE ─────────────────────────────────────────────
# Get these from: https://dashboard.stripe.com/apikeys
# Use TEST keys (sk_test_..., pk_test_...) for development
# Switch to LIVE keys (sk_live_..., pk_live_...) for production

STRIPE_SECRET_KEY=sk_live_REPLACE_WITH_YOUR_SECRET_KEY
STRIPE_PRICE_ID=price_REPLACE_WITH_YOUR_PRICE_ID

# Get this from: Stripe Dashboard → Developers → Webhooks
# → Add endpoint → select events → reveal signing secret
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_WEBHOOK_SECRET

# ── EMAIL ──────────────────────────────────────────────
# For small volume (< 100 emails/day): use Gmail
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=your.gmail@gmail.com
#   SMTP_PASS=your_app_password  ← NOT your Gmail password!
#             Create at: myaccount.google.com → Security → App passwords

# For production (recommended): use Resend or Postmark
#   Resend: SMTP_HOST=smtp.resend.com, SMTP_PORT=465, SMTP_SECURE=true
#           Get API key: resend.com

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your.email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=your.email@gmail.com

# ── LICENSE ────────────────────────────────────────────
# A random secret string used when generating license keys.
# Make this long and random. Keep it secret.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LICENSE_SALT=replace_with_a_long_random_secret_string

# ── SERVER ─────────────────────────────────────────────
PORT=3000
